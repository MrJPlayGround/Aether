# AetherV1 environment template

# Core
AETHER_ENV=development
AETHER_MODE=paper
AETHER_VENUE=blofin
AETHER_RUNTIME_DIR=.runtime

# BloFin
BLOFIN_API_KEY=
BLOFIN_API_SECRET=
BLOFIN_PASSPHRASE=
BLOFIN_USE_DEMO=true
BLOFIN_REST_BASE_URL=
BLOFIN_WS_PUBLIC_URL=
BLOFIN_WS_PRIVATE_URL=
BLOFIN_IP_ALLOWLISTED=false

# Strategy defaults
AETHER_DEFAULT_STRATEGY=vwap_reclaim
AETHER_SYMBOLS=BTC-USDT,ETH-USDT
AETHER_TIMEFRAME=5m

# Risk defaults
AETHER_MAX_NOTIONAL_PER_TRADE=0
AETHER_MAX_OPEN_POSITIONS=1
AETHER_MAX_DAILY_LOSS=0
AETHER_ENABLE_KILL_SWITCH=true

# Ops
AETHER_LOG_LEVEL=info
AETHER_ALERTS_ENABLED=false

